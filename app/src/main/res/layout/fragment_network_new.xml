<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:id="@+id/tv_wifi_ssid" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark" android:textSize="16sp" />
        <TextView android:id="@+id/tv_wifi_signal" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark_secondary" android:textSize="14sp" />
        <TextView android:id="@+id/tv_wifi_speed" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark_secondary" android:textSize="14sp" />
        <TextView android:id="@+id/tv_wifi_ip" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark_secondary" android:textSize="14sp" />

        <TextView android:id="@+id/tv_mobile_type" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark" android:textSize="14sp"
            android:layout_marginTop="16dp" />
        <TextView android:id="@+id/tv_mobile_operator" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark_secondary" android:textSize="14sp" />
        <TextView android:id="@+id/tv_mobile_signal" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark_secondary" android:textSize="14sp" />
        <TextView android:id="@+id/tv_mobile_roaming" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark_secondary" android:textSize="14sp" />

        <TextView android:id="@+id/tv_gps_enabled" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark" android:textSize="14sp"
            android:layout_marginTop="16dp" />
        <TextView android:id="@+id/tv_gps_satellites" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark_secondary" android:textSize="14sp" />
        <TextView android:id="@+id/tv_gps_coord" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="N/A"
            android:textColor="@color/text_on_dark_secondary" android:textSize="14sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_satellites"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_net_interfaces"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone" />

        <com.example.deviceinfoviewer.widget.MonitorChartView
            android:id="@+id/chart_net_activity"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
