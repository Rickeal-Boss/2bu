<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="8dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== WiFi 状态卡（青色） ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_bg_dark"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="4dp" android:layout_height="18dp"
                        android:background="@color/network_color" android:layout_marginEnd="8dp" />
                    <TextView
                        android:text="WiFi 状态"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_wifi_ssid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_on_dark"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:text="信号"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tv_wifi_signal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textColor="@color/network_color"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:text="速率"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tv_wifi_speed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textColor="@color/network_color"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_wifi_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== 移动网络卡 ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_bg_dark"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="4dp" android:layout_height="18dp"
                        android:background="@color/network_color" android:layout_marginEnd="8dp" />
                    <TextView
                        android:text="移动网络"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="6dp">
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:text="类型" android:textColor="@color/text_on_dark_secondary"
                            android:textSize="11sp" />
                        <TextView android:id="@+id/tv_mobile_type" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="N/A"
                            android:textColor="@color/network_color" android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:text="运营商" android:textColor="@color/text_on_dark_secondary"
                            android:textSize="11sp" />
                        <TextView android:id="@+id/tv_mobile_operator" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="N/A"
                            android:textColor="@color/network_color" android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="6dp">
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:text="信号" android:textColor="@color/text_on_dark_secondary"
                            android:textSize="11sp" />
                        <TextView android:id="@+id/tv_mobile_signal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="N/A"
                            android:textColor="@color/text_on_dark" android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:text="漫游" android:textColor="@color/text_on_dark_secondary"
                            android:textSize="11sp" />
                        <TextView android:id="@+id/tv_mobile_roaming" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="N/A"
                            android:textColor="@color/text_on_dark" android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== 网络活动图表 ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_bg_dark"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <View android:layout_width="4dp" android:layout_height="18dp"
                        android:background="@color/network_color" android:layout_marginEnd="8dp" />
                    <TextView
                        android:text="网络活动"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.example.deviceinfoviewer.widget.MonitorChartView
                    android:id="@+id/chart_net_activity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== GPS 状态 ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_bg_dark"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="4dp" android:layout_height="18dp"
                        android:background="@color/network_color" android:layout_marginEnd="8dp" />
                    <TextView
                        android:text="GPS 状态"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="6dp">
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:text="状态" android:textColor="@color/text_on_dark_secondary"
                            android:textSize="11sp" />
                        <TextView android:id="@+id/tv_gps_enabled" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="N/A"
                            android:textColor="@color/text_on_dark" android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:text="卫星数" android:textColor="@color/text_on_dark_secondary"
                            android:textSize="11sp" />
                        <TextView android:id="@+id/tv_gps_satellites" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textColor="@color/text_on_dark" android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <TextView android:id="@+id/tv_gps_coord" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text=""
                    android:textColor="@color/text_on_dark_secondary" android:textSize="11sp"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
