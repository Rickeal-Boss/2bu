<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="8dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== CPU 设备信息头部卡片（橙色） ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_bg_dark"
            app:strokeColor="@color/card_stroke_dark"
            app:strokeWidth="0dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <!-- 芯片图标 -->
                <LinearLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:gravity="center"
                    android:background="@drawable/bg_chip_icon"
                    android:backgroundTint="@color/cpu_color"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:id="@+id/tv_chip_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPU"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_cpu_model"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_on_dark"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_cpu_spec"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== 温度状态卡片（橙色） ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_bg_dark"
            app:strokeColor="@color/card_stroke_dark"
            app:strokeWidth="0dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@color/cpu_color"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="CPU 温度"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_temp_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="正常"
                        android:textColor="@color/status_good"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <com.example.deviceinfoviewer.widget.MonitorChartView
                    android:id="@+id/chart_cpu_temp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Cluster / Per Core 切换（橙色主题） ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_bg_dark"
            app:strokeColor="@color/card_stroke_dark"
            app:strokeWidth="0dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- 切换按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"
                    android:background="#1AFFFFFF"
                    app:cornerRadius="8dp">

                    <TextView
                        android:id="@+id/tab_cluster"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Per cluster"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:background="@drawable/bg_tab_left"
                        android:backgroundTint="@color/cpu_color"
                        android:textColor="@android:color/white"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tab_per_core"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Per core"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:background="@drawable/bg_tab_right"
                        android:textColor="@color/text_on_dark_secondary"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Cluster 视图容器 -->
                <LinearLayout
                    android:id="@+id/cluster_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Per Core 视图容器 -->
                <LinearLayout
                    android:id="@+id/per_core_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
