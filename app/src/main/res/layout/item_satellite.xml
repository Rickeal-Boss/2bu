<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/tv_sat_flag"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:text="🛰"
        android:textSize="16sp"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tv_sat_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/na"
            android:textSize="14sp"
            android:textColor="@color/text_on_dark" />

        <TextView
            android:id="@+id/tv_sat_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/na"
            android:textSize="12sp"
            android:textColor="@color/text_on_dark_secondary"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_sat_snr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/na"
        android:textSize="12sp"
        android:textColor="@color/network_color"
        android:gravity="end" />

</LinearLayout>
