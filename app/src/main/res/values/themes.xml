<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 日间主题 — DevCheck Pro 风格（深色优先、默认为暗） -->
    <style name="Theme.DeviceInfoViewer" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorOnBackground">@color/text_on_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_on_dark</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <!-- 仪表盘卡片样式 — 深色主题 -->
    <style name="DashboardCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_bg_dark</item>
        <item name="strokeColor">@color/card_stroke_dark</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">14dp</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <!-- 信息卡片标题 -->
    <style name="CardTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_on_dark_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- 卡片数值（大字体） -->
    <style name="CardValue" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textColor">@color/cpu_color</item>
        <item name="android:textSize">30sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- 标签样式 -->
    <style name="LabelText" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_on_dark_secondary</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- 分组标题 -->
    <style name="SectionHeader" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:paddingStart">4dp</item>
    </style>

    <!-- 详情行：标签 + 数值 -->
    <style name="DetailRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:paddingHorizontal">14dp</item>
    </style>

    <style name="DetailLabel">
        <item name="android:textColor">@color/text_on_dark_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="DetailValue">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">end</item>
    </style>

    <!-- 图表标题样式 -->
    <style name="ChartTitle">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <!-- 芯片信息标签样式 -->
    <style name="ChipLabel">
        <item name="android:textColor">@color/text_on_dark_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="ChipValue">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Tab 文字样式 — 兼容 Material 3 主题 -->
    <style name="TabTextAppearance" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="textAllCaps">false</item>
    </style>
</resources>
